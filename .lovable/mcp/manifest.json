{
  "version": 1,
  "sdk_version": "0.20.1",
  "path": "/mcp",
  "auth": {
    "type": "oauth",
    "issuer": "https://qbavewdkfserwwnmymoo.supabase.co/auth/v1",
    "accepted_audiences": [
      "authenticated"
    ]
  },
  "mcp": {
    "server": {
      "name": "spendly-mcp",
      "version": "0.1.0",
      "title": "Spendly"
    },
    "tools": [
      {
        "name": "log_transaction",
        "title": "Log a transaction",
        "description": "Record a new expense or income for the signed-in Spendly user. Amount in INR.",
        "annotations": {
          "readOnlyHint": false,
          "destructiveHint": false,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "amount": {
              "type": "number",
              "exclusiveMinimum": 0,
              "description": "Amount in INR (positive)."
            },
            "kind": {
              "default": "expense",
              "type": "string",
              "enum": [
                "expense",
                "income"
              ]
            },
            "category": {
              "description": "e.g. food, chai, transport, salary",
              "type": "string"
            },
            "note": {
              "description": "Free-text note or merchant name.",
              "type": "string"
            },
            "occurred_at": {
              "description": "ISO timestamp; defaults to now.",
              "type": "string",
              "format": "date-time",
              "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$"
            }
          },
          "required": [
            "amount"
          ]
        },
        "outputSchema": null
      },
      {
        "name": "list_transactions",
        "title": "List transactions",
        "description": "List the signed-in Spendly user's most recent transactions, newest first.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "limit": {
              "default": 20,
              "type": "integer",
              "minimum": 1,
              "maximum": 100
            },
            "kind": {
              "type": "string",
              "enum": [
                "expense",
                "income"
              ]
            }
          }
        },
        "outputSchema": null
      },
      {
        "name": "spend_summary",
        "title": "Spending summary",
        "description": "Return total expense and income for the signed-in Spendly user over the last N days (default 30), grouped by category.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "days": {
              "default": 30,
              "type": "integer",
              "minimum": 1,
              "maximum": 365
            }
          }
        },
        "outputSchema": null
      }
    ]
  }
}
